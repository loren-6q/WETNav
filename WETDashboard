<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WET Business Hub</title>
    <style>
        body { background: #111; color: white; font-family: sans-serif; margin: 0; padding-top: 60px; display: flex; flex-direction: column; align-items: center; }
        .hub-container { max-width: 900px; width: 90%; text-align: center; margin-top: 40px; }
        h1 { color: #37b5ff; margin-bottom: 30px; letter-spacing: 2px; }
        
        /* Grid for the Auto-Buttons */
        #launchpad { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; width: 100%; }
        
        .hub-card { 
            background: #222; border: 1px solid #333; padding: 30px 20px; border-radius: 12px; 
            text-decoration: none; color: white; font-weight: bold; font-size: 18px;
            transition: 0.3s; display: flex; flex-direction: column; align-items: center; gap: 10px;
        }
        .hub-card:hover { background: #333; border-color: gold; transform: translateY(-5px); color: gold; }
        .hub-card span { font-size: 12px; font-weight: normal; color: #999; }
    </style>
</head>
<body>

    <div class="hub-container">
        <h1>BUSINESS COMMAND CENTER</h1>
        <div id="launchpad">
            </div>
    </div>

    <script src="nav.js"></script>

    <script>
        // Wait for the Nav to finish injecting
        window.addEventListener('load', () => {
            const launchpad = document.getElementById('launchpad');
            
            // Find every link in your global-nav
            const navLinks = document.querySelectorAll('#global-nav a');

            navLinks.forEach(link => {
                // Skip the "Home" link and the "Logo" link so we don't loop
                if (link.innerText === 'WET' || link.innerText === 'Home') return;

                // Create a big card for the dashboard
                const card = document.createElement('a');
                card.className = 'hub-card';
                card.href = link.href;
                
                // Clean up the text (remove the arrows/emojis if you want)
                const cleanText = link.innerText.replace('▾', '').trim();
                
                card.innerHTML = `
                    <div>${cleanText}</div>
                    <span>Launch Tool ➔</span>
                `;
                
                launchpad.appendChild(card);
            });
        });
    </script>
</body>
</html>
